# ==============================================================================
# INTERN LOGBOOK DEPLOYMENT CONFIGURATION
# Copy this file to '.env' and modify the values for your production deployment.
# DO NOT commit the actual '.env' file to version control.
# ==============================================================================

# Application Security
# A long, cryptographically random string used to sign session cookies.
# Generate one using: python -c "import secrets; print(secrets.token_hex(24))"
SECRET_KEY=replace_this_with_a_secure_random_string

# Domain Name
# Used by Caddy to automatically provision Let's Encrypt SSL/TLS certificates.
DOMAIN=example.com

# Timezone Configuration
# Used by the application to compute 'today' and calculate clock-ins accurately.
APP_TZ=Asia/Manila
TZ=Asia/Manila

# Database Credentials
# Must match the credentials used by the PostgreSQL container.
POSTGRES_USER=admin
POSTGRES_PASSWORD=your_secure_db_password
POSTGRES_DB=attendance_db

# Web Server (Optional Overrides)
PORT=5000
