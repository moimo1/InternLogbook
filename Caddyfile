{$DOMAIN} {
	# Proxy all traffic to the internal Gunicorn web server on port 5000
	reverse_proxy web_app:5000

	# Optional: Enable compression for faster load times
	encode gzip zstd

	# Optional: Basic security headers
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "SAMEORIGIN"
	}
}
